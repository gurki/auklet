PORT=8899

# audible marketplace for login (one of: fr com co.uk de it es ca com.au in co.jp)
AUDIBLE_LOCALE=de

# home timezone for month / local-time bucketing
AUKLET_TZ=Europe/Berlin

# how often to poll the library + wishlist, and how long a listen must go quiet
# before its inferred session is closed
PROGRESS_INTERVAL_S=60
SESSION_GAP_S=300

# journey server sync (optional - only pushes if both token + client id are set)
JOURNEY_URL=http://127.0.0.1:8090
JOURNEY_TOKEN="YOUR_JOURNEY_CLIENT_TOKEN"
JOURNEY_CLIENT_ID="YOUR_JOURNEY_CLIENT_ID"
